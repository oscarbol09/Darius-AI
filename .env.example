# ═════════════════════════════════════════════════════════════════════════════
#  DARIUS AI — Variables de Entorno
#  Copia este archivo como .env y completa los valores.
#  .env NO debe subirse a Git (ya está en .gitignore).
# ═════════════════════════════════════════════════════════════════════════════

# ── Google Gemini (obligatorio para IA) ──────────────────────────────────────
# Consigue tu API key en: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── OpenRouter (fallback cuando Gemini falla) ─────────────────────────────────
# Opcional. Consigue tu API key en: https://openrouter.ai/keys
OPENROUTER_API_KEY=

# ── Porcupine (detección de wake-word "Darius") ──────────────────────────────
# Opcional (solo escritorio). Consigue AccessKey en: https://console.picovoice.ai/
PORCUPINE_ACCESS_KEY=

# ── Supabase (persistencia compartida) ───────────────────────────────────────
# Opcional (si falta, funciona en modo 100% local).
# Consíguelos en: Project Settings → API
SUPABASE_URL=
SUPABASE_KEY=
